# Copy to .env for local development. In Azure, these are App Settings /
# Key Vault references — see docs/02-configuration.md. Never commit .env.

# --- Azure SQL ---------------------------------------------------------------
# Option A (preferred in Azure): server + database, auth via DefaultAzureCredential
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=condb
# Option B (local dev / SQL auth): full ODBC connection string; wins when set
#SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-server.database.windows.net,1433;Database=condb;Uid=...;Pwd=...;Encrypt=yes;

# --- Azure Storage (ingestion triggers) --------------------------------------
STORAGE_CONNECTION=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
SNAPSHOT_CONTAINER=index-snapshots
REPORT_CONTAINER=weekly-reports

# --- Search (api/) ------------------------------------------------------------
FULLTEXT_ENABLED=true
SEARCH_ENDPOINT=https://your-search.search.windows.net
#SEARCH_API_KEY=            # optional; DefaultAzureCredential when absent
SEARCH_INDEX=con-records

# --- Azure OpenAI (natural-language /ask endpoint + embeddings) ---------------
AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com
#AZURE_OPENAI_API_KEY=      # optional; DefaultAzureCredential when absent
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Key Vault (optional; app settings normally use Key Vault references) -----
#KEY_VAULT_URI=https://your-kv.vault.azure.net
